# ── KGC Lite Backend Production Environment Variables ──
# Copy this file to .env locally to test, or add these to your Render dashboard

# 1. Security (Set to false in production)
DEBUG=false

# 2. Secret Key (Render generates this automatically via render.yaml, but if local, generate one)
SECRET_KEY=your_secure_random_string_here

# 3. Database URL (Render generates this automatically via render.yaml)
DATABASE_URL=postgresql+asyncpg://user:pass@host/db
SYNC_DATABASE_URL=postgresql://user:pass@host/db

# 4. Gemini API Key (Required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# 5. Frontend Origin (Required for CORS)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# 6. SMS Configuration (Optional for console, required for real SMS)
SMS_PROVIDER=console  # Options: console, msg91
MSG91_API_KEY=your_msg91_key_here
MSG91_SENDER_ID=KGCAI
