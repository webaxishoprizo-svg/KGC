# ── KGC Lite Frontend Production Environment Variables ──
# Add these variables to your Vercel/Netlify dashboard

# 1. API URL (Required - Point this to your Render backend URL)
VITE_API_URL=https://your-backend-app.onrender.com

# 2. MSG91 Auth Token (Required for OTP login)
VITE_MSG91_TOKEN=your_msg91_token_here
